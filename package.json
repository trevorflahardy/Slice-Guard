{
    "name": "slice-guard-monorepo",
    "private": true,
    "workspaces": [
        "slice-guard/backend",
        "slice-guard/frontend"
    ],
    "scripts": {
        "install:backend": "bun install --cwd slice-guard/backend",
        "install:frontend": "bun install --cwd slice-guard/frontend",
        "install:all": "bun install",
        "dev:backend": "bun run --cwd slice-guard/backend dev",
        "dev:frontend": "bun run --cwd slice-guard/frontend dev",
        "build": "bun run build:backend && bun run build:frontend",
        "build:backend": "bun run --cwd slice-guard/backend build",
        "build:frontend": "bun run --cwd slice-guard/frontend build",
        "dev": "bun run dev:frontend",
        "clean": "bun run --cwd slice-guard/backend clean && bun run --cwd slice-guard/frontend clean",
        "test": "bun run --cwd slice-guard/backend test && bun run --cwd slice-guard/frontend test",
        "lint": "bun run lint:frontend && bun run lint:backend",
        "lint:frontend": "bun run --cwd slice-guard/frontend lint",
        "lint:backend": "bun run --cwd slice-guard/backend lint",
        "lint:fix": "bun run lint:fix:frontend && bun run lint:fix:backend",
        "lint:fix:frontend": "bun run --cwd slice-guard/frontend lint:fix",
        "lint:fix:backend": "bun run --cwd slice-guard/backend lint:fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "slice-guard/frontend/**/*.{js,ts,vue}": [
            "cd slice-guard/frontend && bunx eslint --fix",
            "prettier --write"
        ],
        "slice-guard/backend/**/*.{js,ts}": [
            "cd slice-guard/backend && bunx eslint --fix",
            "prettier --write"
        ],
        "**/*.{json,md,yml,yaml}": [
            "prettier --write"
        ],
        "**/*.xml": [
            "prettier --write --plugin @prettier/plugin-xml"
        ]
    },
    "dependencies": {},
    "devDependencies": {
        "@prettier/plugin-xml": "^3.4.2",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.4",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.6.14"
    }
}
