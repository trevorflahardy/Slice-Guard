{
    "name": "slice-guard-monorepo",
    "private": true,
    "workspaces": [
        "slice-guard/backend",
        "slice-guard/frontend"
    ],
    "scripts": {
        "install:backend": "bun install --cwd slice-guard/backend",
        "install:frontend": "bun install --cwd slice-guard/frontend",
        "install:all": "bun install",
        "dev:backend": "bun --cwd slice-guard/backend run dev",
        "dev:frontend": "bun --cwd slice-guard/frontend run dev",
        "build": "bun run build:backend && bun run build:frontend",
        "build:backend": "bun --cwd slice-guard/backend run build",
        "build:frontend": "bun --cwd slice-guard/frontend run build",
        "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
        "clean": "bun --cwd slice-guard/backend run clean && bun --cwd slice-guard/frontend run clean",
        "test": "bun --cwd slice-guard/backend run test && bun --cwd slice-guard/frontend run test"
    }
}