{
  "name": "slice-guard-backend",
  "version": "0.1.0",
  "description": "A Bun-based backend for Slice Guard for authentication and management.",
  "type": "module",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run src/server.ts --watch",
    "build": "bun build ./src/server.ts --target=bun",
    "test": "bun test",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.7.0",
    "@aws-sdk/client-s3": "^3.541.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8"
  }
}
